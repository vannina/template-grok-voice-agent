# --- xAI Grok Voice -----------------------------------------------------
# Required. https://console.x.ai/
XAI_API_KEY=your-xai-api-key-here

# --- Composio (Google Calendar) — optional ------------------------------
# Needed if you want Margot to actually book reservations.
# https://composio.dev → connect Google Calendar → create an MCP server.
COMPOSIO_API_KEY=
COMPOSIO_MCP_URL=

# --- Twilio — optional, only if you wire the phone path -----------------
# Required for /twilio/voice + /twilio/stream to be able to hang up cleanly
# after the agent's "au revoir" (otherwise the call stays open with silence).
# Account SID + Auth Token from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Prospection sortante (chemin outbound) — optionnel ------------------
# Table Airtable du registre d'opposition (défaut : "Prospection — Oppositions",
# le nom réel de la table créée par le WF ; ne surcharger que si renommée).
#OPPOSITIONS_TABLE=Prospection — Oppositions
# Barge-in téléphone : ms d'audio agent déjà streamées avant qu'un
# speech_started puisse couper la réponse (anti-boucle « Allô ? »). Défaut 900.
#BARGE_IN_MIN_MS=900
# Watchdog outbound : relance après N s de silence (défaut 7), clôture polie
# + raccrochage N s après la relance (défaut 8).
#WD_RELANCE_S=7
#WD_CLOSE_S=8
