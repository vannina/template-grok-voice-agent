# --- xAI Grok Voice -----------------------------------------------------
# Required. https://console.x.ai/
XAI_API_KEY=your-xai-api-key-here

# --- Composio (Google Calendar) — optional ------------------------------
# Needed if you want Margot to actually book reservations.
# https://composio.dev → connect Google Calendar → create an MCP server.
COMPOSIO_API_KEY=
COMPOSIO_MCP_URL=

# --- Twilio — optional, only if you wire the phone path -----------------
# Required for /twilio/voice + /twilio/stream to be able to hang up cleanly
# after the agent's "au revoir" (otherwise the call stays open with silence).
# Account SID + Auth Token from https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
